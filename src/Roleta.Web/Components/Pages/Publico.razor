@page "/publico"
@layout PublicLayout
@implements IDisposable
@inject ShowState Show

<PageTitle>Roleta — Telão</PageTitle>

<div class="public-scores">
    @foreach (var p in Show.Players)
    {
        <div class="public-player">
            <div class="public-player-score">
                <span class="seg-display score">
                    <span class="ghost">88</span>
                    <span class="val">@p.Score</span>
                </span>
            </div>
            <div class="public-player-name show-text">@p.Name</div>
        </div>
    }
</div>

<div class="public-board @(Show.TimerTotalSeconds > 0 ? "with-timer" : "")">
    @if (Show.IsAudiencePending)
    {
        <div class="audience-cue" @key="Show.RevealSeq">
            <div class="confetti" aria-hidden="true">
                @for (var i = 0; i < 48; i++)
                {
                    <span class="confetti-piece" style="--i:@i"></span>
                }
            </div>
            <div class="audience-cue-title show-text">Regra da Plateia</div>
        </div>
    }
    else if (Show.DisplayVisible && Show.Current is { Kind: RevealKind.Modifier, ModifierKind: { } mk } c)
    {
        <div class="mod-card mod-@mk.CssClass()" style="--accent: var(--show-modifier)" @key="Show.RevealSeq">
            <span class="public-kind-chip">Modificador</span>
            <div class="mod-frame">
            @switch (mk)
            {
                case ModifierKind.Flip:
                    <div class="mod-flip-scene">
                        <div class="mod-flip-inner">
                            <div class="mod-face mod-face-front" aria-hidden="true">
                                <span class="mod-flip-glyph">↻</span>
                            </div>
                            <div class="mod-face mod-face-back">
                                <div class="mod-title show-text">@c.Text</div>
                            </div>
                        </div>
                    </div>
                    break;
                case ModifierKind.Swap:
                    <div class="mod-swap-scene">
                        <div class="mod-move-row" aria-hidden="true">
                            <div class="mod-move-card swap-a"></div>
                            <div class="mod-move-card swap-b"></div>
                        </div>
                        <div class="mod-title show-text">@c.Text</div>
                    </div>
                    break;
                case ModifierKind.Clone:
                    <div class="mod-clone-scene">
                        <div class="mod-clone-stack" aria-hidden="true">
                            <div class="mod-clone-card original"></div>
                            <div class="mod-clone-card ghost"></div>
                        </div>
                        <div class="mod-title show-text">@c.Text</div>
                    </div>
                    break;
                case ModifierKind.Left:
                    <div class="mod-shift-scene mod-left">
                        <div class="mod-move-row" aria-hidden="true">
                            <div class="mod-move-card"></div>
                            <div class="mod-move-card"></div>
                            <div class="mod-move-card"></div>
                        </div>
                        <div class="mod-title show-text">@c.Text</div>
                    </div>
                    break;
                case ModifierKind.Right:
                    <div class="mod-shift-scene mod-right">
                        <div class="mod-move-row" aria-hidden="true">
                            <div class="mod-move-card"></div>
                            <div class="mod-move-card"></div>
                            <div class="mod-move-card"></div>
                        </div>
                        <div class="mod-title show-text">@c.Text</div>
                    </div>
                    break;
            }
            </div>
        </div>
    }
    else if (Show.DisplayVisible && Show.Current is { } reveal)
    {
        <div class="public-reveal @(Show.IsFlipReveal ? "flip" : "")" style="--accent: @AccentColor()" @key="Show.RevealSeq">
            <span class="public-kind-chip">@ChipLabel(reveal)</span>
            <div class="public-frame">
                <div class="public-frame-text show-text">@reveal.Text</div>
            </div>
        </div>
    }
    @if (Show.TimerTotalSeconds > 0)
    {
        <div class="public-timer @(Show.TimerRemainingSeconds <= 5 ? "ending" : "")">
            <span class="score">@Show.TimerRemainingSeconds</span>
        </div>
    }
</div>

@code {
    protected override void OnInitialized() => Show.Changed += OnChanged;

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private string AccentColor() => Show.Current switch
    {
        { Kind: RevealKind.Rule, Color: Color.White } => "#f0e6c8",
        { Kind: RevealKind.Rule, Color: { } color } => color.HexColor(),
        { Kind: RevealKind.Modifier } => "var(--show-modifier)",
        { Kind: RevealKind.Action } => "var(--show-action)",
        _ => "#333333",
    };

    private static string ChipLabel(Reveal c) => c switch
    {
        { Kind: RevealKind.Rule, Color: Color.White } => "Regra da Plateia",
        { Kind: RevealKind.Rule } => "Regra",
        { Kind: RevealKind.Modifier } => "Modificador",
        { Kind: RevealKind.Action } => "Ação",
        _ => string.Empty,
    };

    public void Dispose() => Show.Changed -= OnChanged;
}
