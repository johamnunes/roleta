@page "/cadastro/modificadores"
@inject ICatalogService Catalog
@inject IJSRuntime JS

<PageTitle>Cadastro de Modificadores</PageTitle>

<div class="d-flex align-items-center gap-3 flex-wrap mb-3">
    <h1 class="mb-0">🔀 Modificadores</h1>
    <button class="btn btn-primary ms-auto" @onclick="StartNew">+ Novo modificador</button>
</div>

@if (editModel is not null)
{
    <EditForm Model="editModel" OnValidSubmit="SaveAsync" class="card card-body mb-4 shadow-sm">
        <DataAnnotationsValidator />
        <h5>@(IsNew ? "Novo modificador" : "Editar modificador")</h5>

        <div class="row g-3">
            <div class="col-12 col-md-8">
                <label class="form-label">Nome (vai para a TV)</label>
                <InputText @bind-Value="editModel.Name" class="form-control" placeholder="ex.: SWAP" />
                <ValidationMessage For="() => editModel.Name" />
            </div>
            <div class="col-12 col-md-4 d-flex align-items-end">
                <div class="form-check">
                    <InputCheckbox @bind-Value="editModel.IsActive" class="form-check-input" id="modActive" />
                    <label class="form-check-label" for="modActive">Ativo (entra nos sorteios)</label>
                </div>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success">Salvar</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Cancelar</button>
        </div>
    </EditForm>
}

@if (items.Count == 0)
{
    <p class="text-secondary"><em>Nenhum modificador cadastrado.</em></p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Nome</th>
                <th class="text-center">Ativo</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in items)
            {
                <tr class="@(m.IsActive ? "" : "opacity-50")">
                    <td class="fw-semibold">@m.Name</td>
                    <td class="text-center">@(m.IsActive ? "✅" : "—")</td>
                    <td class="text-end text-nowrap">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(m)">Editar</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(m)">Excluir</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-secondary"><small>@items.Count modificador(es).</small></p>
}

@code {
    private IReadOnlyList<ModifierDefinition> items = [];
    private ModifierDefinition? editModel;
    private bool IsNew => editModel is not null && items.All(m => m.Id != editModel.Id);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => items = await Catalog.GetModifiersAsync();

    private void StartNew() => editModel = new ModifierDefinition();

    private void Edit(ModifierDefinition m) => editModel = new ModifierDefinition
    {
        Id = m.Id,
        Name = m.Name,
        IsActive = m.IsActive,
        CreatedAt = m.CreatedAt,
        UpdatedAt = m.UpdatedAt,
    };

    private void Cancel() => editModel = null;

    private async Task SaveAsync()
    {
        await Catalog.SaveModifierAsync(editModel!);
        editModel = null;
        await LoadAsync();
    }

    private async Task DeleteAsync(ModifierDefinition m)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Excluir o modificador \"{m.Name}\"?"))
            return;
        await Catalog.DeleteModifierAsync(m.Id);
        if (editModel?.Id == m.Id) editModel = null;
        await LoadAsync();
    }
}
