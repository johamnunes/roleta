@page "/cadastro/regras"
@inject ICatalogService Catalog
@inject IJSRuntime JS

<PageTitle>Cadastro de Regras</PageTitle>

<div class="d-flex align-items-center gap-3 flex-wrap mb-3">
    <h1 class="mb-0">📜 Regras</h1>
    <select class="form-select w-auto" value="@(filter?.ToString() ?? "")" @onchange="OnFilterChanged">
        <option value="">Todas as cores</option>
        @foreach (var c in colors)
        {
            <option value="@c">@c.Label()</option>
        }
    </select>
    <button class="btn btn-primary ms-auto" @onclick="() => StartNew()">+ Nova regra</button>
</div>

@if (editModel is not null)
{
    <EditForm Model="editModel" OnValidSubmit="SaveAsync" class="card card-body mb-4 shadow-sm">
        <DataAnnotationsValidator />
        <h5>@(IsNew ? "Nova regra" : "Editar regra")</h5>

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label">Cor / pool</label>
                <InputSelect @bind-Value="editModel.Color" class="form-select">
                    @foreach (var c in colors)
                    {
                        <option value="@c">@c.Label() — @c.Theme()</option>
                    }
                </InputSelect>
            </div>
            <div class="col-12 col-md-8 d-flex align-items-end">
                <div class="form-check">
                    <InputCheckbox @bind-Value="editModel.IsActive" class="form-check-input" id="ruleActive" />
                    <label class="form-check-label" for="ruleActive">Ativa (entra nos sorteios)</label>
                </div>
            </div>
            <div class="col-12">
                <label class="form-label">Texto da regra (vai para a TV)</label>
                <InputTextArea @bind-Value="editModel.Text" class="form-control" rows="2" />
                <ValidationMessage For="() => editModel.Text" />
            </div>
            <div class="col-12">
                <label class="form-label">Oposto (para o modificador Flip) <span class="text-secondary">— opcional</span></label>
                <InputTextArea @bind-Value="editModel.OppositeText" class="form-control" rows="2" />
                <ValidationMessage For="() => editModel.OppositeText" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">Nota do juiz — regra base <span class="text-secondary">— opcional, não vai p/ TV</span></label>
                <InputText @bind-Value="editModel.JudgeNotes" class="form-control" />
                <ValidationMessage For="() => editModel.JudgeNotes" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">Nota do juiz — oposto <span class="text-secondary">— opcional, não vai p/ TV</span></label>
                <InputText @bind-Value="editModel.OppositeJudgeNotes" class="form-control" />
                <ValidationMessage For="() => editModel.OppositeJudgeNotes" />
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="btn btn-success">Salvar</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Cancelar</button>
        </div>
    </EditForm>
}

@if (items.Count == 0)
{
    <p class="text-secondary"><em>Nenhuma regra cadastrada.</em></p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Cor</th>
                <th>Texto</th>
                <th>Oposto</th>
                <th class="text-center">Ativa</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in items)
            {
                <tr class="@(r.IsActive ? "" : "opacity-50")">
                    <td><span class="badge @r.Color.BadgeClass()">@r.Color.Label()</span></td>
                    <td>@r.Text</td>
                    <td class="text-secondary"><small>@r.OppositeText</small></td>
                    <td class="text-center">@(r.IsActive ? "✅" : "—")</td>
                    <td class="text-end text-nowrap">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(r)">Editar</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(r)">Excluir</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-secondary"><small>@items.Count regra(s) listada(s).</small></p>
}

@code {
    private static readonly Color[] colors = Enum.GetValues<Color>();

    private IReadOnlyList<RuleDefinition> items = [];
    private RuleDefinition? editModel;
    private Color? filter;
    private bool IsNew => editModel is not null && items.All(r => r.Id != editModel.Id);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync() => items = await Catalog.GetRulesAsync(filter);

    private async Task OnFilterChanged(ChangeEventArgs e)
    {
        var s = e.Value?.ToString();
        filter = string.IsNullOrEmpty(s) ? null : Enum.Parse<Color>(s);
        await LoadAsync();
    }

    private void StartNew() => editModel = new RuleDefinition { Color = filter ?? Color.Blue };

    private void Edit(RuleDefinition r) => editModel = new RuleDefinition
    {
        Id = r.Id,
        Color = r.Color,
        Text = r.Text,
        OppositeText = r.OppositeText,
        JudgeNotes = r.JudgeNotes,
        OppositeJudgeNotes = r.OppositeJudgeNotes,
        IsActive = r.IsActive,
        CreatedAt = r.CreatedAt,
        UpdatedAt = r.UpdatedAt,
    };

    private void Cancel() => editModel = null;

    private async Task SaveAsync()
    {
        await Catalog.SaveRuleAsync(editModel!);
        editModel = null;
        await LoadAsync();
    }

    private async Task DeleteAsync(RuleDefinition r)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Excluir a regra \"{r.Text}\"?"))
            return;
        await Catalog.DeleteRuleAsync(r.Id);
        if (editModel?.Id == r.Id) editModel = null;
        await LoadAsync();
    }
}
