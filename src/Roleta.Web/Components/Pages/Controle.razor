@page "/controle"
@implements IDisposable
@inject ICatalogService Catalog
@inject IGameService Games
@inject ShowState Show
@inject IJSRuntime JS

<PageTitle>Roleta — Controle</PageTitle>

<div class="ctrl-page">
    <header class="ctrl-header">
        <div>
            <h1 class="ctrl-title">Controle</h1>
            <p class="ctrl-subtitle">
                @if (Show.HasActiveGame)
                {
                    <span class="ctrl-status-pill is-live">Jogo: @Show.ActiveGameName</span>
                }
                else
                {
                    <span class="ctrl-status-pill">Modo livre</span>
                }
            </p>
        </div>
        <a class="btn btn-outline-dark" href="publico" target="_blank">Abrir telão ↗</a>
    </header>

    @if (message is not null)
    {
        <div class="alert alert-warning py-2 ctrl-alert">@message <button type="button" class="btn-close float-end" @onclick="() => message = null"></button></div>
    }

    <!-- SETUP: longe das ações de palco -->
    <section class="ctrl-panel ctrl-setup">
        <div class="ctrl-panel-head">
            <h2>1 · Preparação</h2>
            <span class="ctrl-panel-hint">Carregar jogo antes do show. Não fica junto dos botões de revelar.</span>
        </div>
        <div class="ctrl-setup-row">
            <select class="form-select ctrl-game-select" value="@selectedGameId" @onchange="e => selectedGameId = e.Value?.ToString()">
                <option value="">— escolher jogo —</option>
                @foreach (var g in savedGames)
                {
                    <option value="@g.Id">@g.Name</option>
                }
            </select>
            <button class="btn btn-primary" @onclick="LoadSelectedGame" disabled="@(string.IsNullOrEmpty(selectedGameId))">Carregar jogo</button>
            <a class="btn btn-outline-secondary" href="cadastro/jogos">Gerenciar jogos</a>
        </div>
    </section>

    <div class="ctrl-main">
        <!-- AO VIVO: revelação -->
        <section class="ctrl-panel ctrl-live">
            <div class="ctrl-panel-head">
                <h2>2 · Revelar na roleta</h2>
                <span class="ctrl-panel-hint">A roleta física parou → um clique só.@(Show.HasActiveGame ? " Números = restantes no jogo." : "")</span>
            </div>

            <div class="ctrl-reveal-grid">
                @foreach (var color in colors)
                {
                    <button type="button"
                            class="ctrl-reveal-btn @ButtonClass(color)"
                            @onclick="() => RevealRule(color)"
                            disabled="@(Show.HasActiveGame && Show.RemainingRules(color) == 0)">
                        <span class="ctrl-reveal-label">Regra @color.Label()</span>
                        @if (Show.HasActiveGame)
                        {
                            <span class="ctrl-reveal-count">@Show.RemainingRules(color)</span>
                        }
                    </button>
                }
            </div>

            <div class="ctrl-reveal-secondary">
                <button type="button" class="ctrl-reveal-btn ctrl-reveal-mod" @onclick="RevealModifier">
                    <span class="ctrl-reveal-label">Modificador</span>
                </button>
                <button type="button" class="ctrl-reveal-btn ctrl-reveal-act" @onclick="RevealAction"
                        disabled="@(Show.HasActiveGame && Show.RemainingActions == 0)">
                    <span class="ctrl-reveal-label">Ação</span>
                    @if (Show.HasActiveGame)
                    {
                        <span class="ctrl-reveal-count">@Show.RemainingActions</span>
                    }
                </button>
            </div>
        </section>

        <!-- TELÃO + PLACAR + TIMER -->
        <div class="ctrl-side">
            <section class="ctrl-panel">
                <div class="ctrl-panel-head">
                    <h2>Telão</h2>
                    <div class="ctrl-inline-actions">
                        @if (Show.DisplayVisible)
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => Show.SetDisplayVisible(false)">Esconder</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => Show.SetDisplayVisible(true)">Mostrar</button>
                        }
                    </div>
                </div>
                <div class="control-reveal-preview">
                    @if (Show.IsAudiencePending)
                    {
                        <div class="text-uppercase small" style="opacity:.7">Regra da Plateia (aguardando revelar)</div>
                        <div class="show-text fs-4">@(Show.CurrentRule?.Text)</div>
                    }
                    else if (Show.Current is { Kind: RevealKind.Modifier } mod)
                    {
                        <div class="text-uppercase small mod-accent" style="--accent:var(--show-modifier);opacity:.85">
                            Modificador @(Show.DisplayVisible ? "" : "(escondido)")
                        </div>
                        <div class="show-text fs-4" style="color:var(--show-modifier)">@mod.Text</div>
                    }
                    else if (Show.Current is { Kind: RevealKind.Action } act)
                    {
                        <div class="text-uppercase small" style="color:var(--show-action);opacity:.85">
                            Ação @(Show.DisplayVisible ? "" : "(escondido)")
                        </div>
                        <div class="show-text fs-4" style="color:var(--show-action)">@act.Text</div>
                    }
                    else if (Show.Current is { } c)
                    {
                        <div class="text-uppercase small" style="opacity:.7">@ChipLabel(c) @(Show.DisplayVisible ? "" : "(escondido)")</div>
                        <div class="show-text fs-4">@c.Text</div>
                    }
                    else
                    {
                        <span class="text-secondary">Nada no telão.</span>
                    }
                </div>
            </section>

            <section class="ctrl-panel">
                <div class="ctrl-panel-head">
                    <h2>Placar</h2>
                </div>
                <div class="ctrl-score-list">
                    @for (var i = 0; i < Show.Players.Count; i++)
                    {
                        var idx = i;
                        var p = Show.Players[idx];
                        <div class="ctrl-score-row">
                            <input class="form-control show-text" value="@p.Name"
                                   @onchange="e => Show.SetPlayerName(idx, e.Value?.ToString() ?? string.Empty)" />
                            <button type="button" class="ctrl-score-btn minus" @onclick="() => Show.AddScore(idx, -1)" aria-label="Menos um">−</button>
                            <span class="ctrl-score-val">@p.Score</span>
                            <button type="button" class="ctrl-score-btn plus" @onclick="() => Show.AddScore(idx, 1)" aria-label="Mais um">+</button>
                        </div>
                    }
                </div>
                <button type="button" class="btn btn-primary w-100 mt-3"
                        disabled="@(!Show.HasActiveGame || Show.ActiveBasePoints <= 0)"
                        title="Define o placar de cada jogador para os pontos base do jogo"
                        @onclick="() => Show.AssignBaseScores()">
                    Atribuir pontos base (@Show.ActiveBasePoints)
                </button>
            </section>

            <section class="ctrl-panel">
                <div class="ctrl-panel-head">
                    <h2>Cronômetro</h2>
                    <span class="ctrl-timer-display @(Show.TimerTotalSeconds > 0 && Show.TimerRemainingSeconds <= 5 ? "ending" : "")">
                        @(Show.TimerTotalSeconds > 0 ? $"{Show.TimerRemainingSeconds}s" : "—")
                    </span>
                </div>
                <div class="ctrl-timer-grid">
                    <button type="button" class="btn btn-primary" @onclick="() => Show.StartTimer(30)">30s</button>
                    <button type="button" class="btn btn-primary" @onclick="() => Show.StartTimer(60)">60s</button>
                    @if (Show.TimerRunning)
                    {
                        <button type="button" class="btn btn-outline-secondary" @onclick="Show.PauseTimer">Pausar</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-primary" @onclick="Show.ResumeTimer"
                                disabled="@(Show.TimerRemainingSeconds <= 0)">Retomar</button>
                    }
                    <button type="button" class="btn btn-outline-secondary" @onclick="() => Show.AddTimerSeconds(10)"
                            disabled="@(Show.TimerTotalSeconds == 0)">+10s</button>
                </div>
            </section>
        </div>
    </div>

    <!-- HISTÓRICO -->
    <section class="ctrl-panel">
        <div class="ctrl-panel-head">
            <h2>3 · Regras que já saíram</h2>
            <span class="ctrl-panel-hint">Mostrar / inverter — ações secundárias.</span>
        </div>
        @if (Show.RuleHistory.Count == 0)
        {
            <p class="text-secondary mb-0"><small>Nenhuma regra revelada ainda.</small></p>
        }
        else
        {
            <div class="ctrl-history-list">
                @foreach (var r in Show.RuleHistory)
                {
                    var flipped = Show.IsRuleFlipped(r.Id);
                    var displayText = flipped && !string.IsNullOrWhiteSpace(r.OppositeText) ? r.OppositeText! : r.Text;
                    <div class="ctrl-history-row">
                        <span class="badge @r.Color.BadgeClass()">@r.Color.Label()</span>
                        @if (flipped)
                        {
                            <span class="badge text-bg-warning">Invertida</span>
                        }
                        <span class="ctrl-history-text show-text" title="@displayText">@displayText</span>
                        <div class="ctrl-history-actions">
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => MostrarRegra(r)">Mostrar</button>
                            <button type="button" class="btn btn-sm @(flipped ? "btn-warning" : "btn-outline-warning")" @onclick="() => InverterRegra(r)"
                                    disabled="@(string.IsNullOrWhiteSpace(r.OppositeText))"
                                    title="@(flipped ? "Voltar para a regra base" : "Alternar para o oposto")">
                                @(flipped ? "Desinverter" : "Inverter")
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <!-- ZONA DE RISCO: ações raras / destrutivas -->
    <section class="ctrl-panel ctrl-danger">
        <div class="ctrl-panel-head">
            <h2>Zona de risco</h2>
            <span class="ctrl-panel-hint">Pedem confirmação. Longe dos botões de revelar.</span>
        </div>
        <div class="ctrl-danger-grid">
            <button type="button" class="btn btn-outline-warning" @onclick="OpenEndGame"
                    disabled="@(!Show.HasActiveGame || string.IsNullOrWhiteSpace(Show.ActiveEndingScript))"
                    title="Mostra o texto de encerramento (mantém o jogo carregado)">
                Fim de jogo
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="ConfirmClearGame"
                    disabled="@(!Show.HasActiveGame)">
                Sair para modo livre
            </button>
            <button type="button" class="btn btn-outline-danger" @onclick="ConfirmClearReveal"
                    disabled="@(Show.Current is null && !Show.IsAudiencePending)">
                Limpar telão
            </button>
            <button type="button" class="btn btn-outline-danger" @onclick="ConfirmResetScores">
                Zerar placar
            </button>
            <button type="button" class="btn btn-outline-danger" @onclick="ConfirmStopTimer"
                    disabled="@(Show.TimerTotalSeconds == 0)">
                Zerar cronômetro
            </button>
        </div>
    </section>
</div>

@if (endGameModalOpen)
{
    <div class="note-modal-backdrop">
        <div class="note-modal">
            <div class="d-flex align-items-center mb-2">
                <span class="badge text-bg-warning">Fim de jogo</span>
                <span class="ms-2 fw-bold">@(Show.ActiveGameName ?? "Encerramento")</span>
                <button type="button" class="btn-close btn-close-white ms-auto" @onclick="() => endGameModalOpen = false"></button>
            </div>
            <p class="text-secondary mb-2"><small>Leia para a plateia. O jogo continua carregado (placar, pools e histórico intactos).</small></p>
            <div class="note-modal-body show-text" style="white-space:pre-wrap;min-height:8rem;font-size:1.25rem;line-height:1.45">
                @Show.ActiveEndingScript
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-secondary ms-auto" @onclick="() => endGameModalOpen = false">Fechar</button>
            </div>
        </div>
    </div>
}
else if (Show.IsAudiencePending && Show.CurrentRule is { } pending)
{
    <div class="note-modal-backdrop">
        <div class="note-modal">
            <div class="d-flex align-items-center mb-2">
                <span class="badge @pending.Color.BadgeClass()">@pending.Color.Label()</span>
                <span class="ms-2 fw-bold">Regra da Plateia</span>
                <button type="button" class="btn-close btn-close-white ms-auto" @onclick="CancelAudienceReveal"></button>
            </div>
            <p class="text-secondary mb-2"><small>O telão está no teaser. Confira a regra e clique em Revelar quando a plateia estiver pronta.</small></p>
            <div class="show-text fs-3 mb-3">@pending.Text</div>
            <div class="note-modal-body">
                @(string.IsNullOrWhiteSpace(pending.JudgeNotes) ? "(sem nota cadastrada)" : pending.JudgeNotes)
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-secondary" @onclick="CancelAudienceReveal">Cancelar</button>
                <button class="btn btn-warning btn-lg ms-auto fw-bold" @onclick="ConfirmAudienceReveal">Revelar</button>
            </div>
        </div>
    </div>
}
else if (noteModalOpen && Show.CurrentRule is { } cr)
{
    <div class="note-modal-backdrop">
        <div class="note-modal">
            <div class="d-flex align-items-center mb-2">
                <span class="badge @cr.Color.BadgeClass()">@cr.Color.Label()</span>
                <span class="ms-2 fw-bold">@(Show.IsShowingOpposite ? "Nota — oposto" : "Nota — regra")</span>
                <button type="button" class="btn-close btn-close-white ms-auto" @onclick="() => noteModalOpen = false"></button>
            </div>
            <div class="show-text fs-3 mb-3">@(Show.IsShowingOpposite ? (cr.OppositeText ?? cr.Text) : cr.Text)</div>
            <div class="note-modal-body">
                @{
                    var note = Show.IsShowingOpposite ? cr.OppositeJudgeNotes : cr.JudgeNotes;
                }
                @(string.IsNullOrWhiteSpace(note) ? "(sem nota cadastrada)" : note)
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-outline-warning" @onclick="() => Show.ToggleRule(cr)"
                        disabled="@(string.IsNullOrWhiteSpace(cr.OppositeText))">Inverter</button>
                <button class="btn btn-secondary ms-auto" @onclick="() => noteModalOpen = false">Fechar</button>
            </div>
        </div>
    </div>
}

@code {
    private static readonly Color[] colors = Enum.GetValues<Color>();
    private string? message;
    private bool noteModalOpen;
    private bool endGameModalOpen;

    [SupplyParameterFromQuery(Name = "jogo")]
    public Guid? JogoId { get; set; }

    private IReadOnlyList<Game> savedGames = [];
    private string? selectedGameId;

    protected override async Task OnInitializedAsync()
    {
        Show.Changed += OnChanged;
        savedGames = await Games.GetGamesAsync();
        if (JogoId is Guid id) await LoadGameById(id);
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadSelectedGame()
    {
        if (Guid.TryParse(selectedGameId, out var id)) await LoadGameById(id);
    }

    private async Task LoadGameById(Guid id)
    {
        if (Show.HasActiveGame)
        {
            var ok = await JS.InvokeAsync<bool>("confirm",
                "Já há um jogo carregado. Carregar outro zera placar, histórico e pools. Continuar?");
            if (!ok) return;
        }

        var game = await Games.GetGameAsync(id);
        if (game is null)
        {
            message = "Jogo não encontrado.";
            return;
        }
        Show.LoadGame(game);
        selectedGameId = id.ToString();
        endGameModalOpen = false;
        message = $"Jogo \"{game.Name}\" carregado. Placar zerado e conteúdo definido.";
    }

    private void OpenEndGame()
    {
        if (string.IsNullOrWhiteSpace(Show.ActiveEndingScript))
        {
            message = "Este jogo não tem texto de fim cadastrado. Edite o jogo em Gerenciar.";
            return;
        }
        endGameModalOpen = true;
        noteModalOpen = false;
    }

    private async Task ConfirmClearGame()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Sair para modo livre? O jogo carregado deixa de controlar os pools (placar permanece)."))
            return;
        Show.ClearGame();
        message = "Modo livre ativo.";
    }

    private async Task ConfirmClearReveal()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Limpar o que está no telão?"))
            return;
        Show.ClearReveal();
    }

    private async Task ConfirmResetScores()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Zerar o placar dos 3 jogadores?"))
            return;
        Show.ResetScores();
    }

    private async Task ConfirmStopTimer()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Zerar o cronômetro?"))
            return;
        Show.StopTimer();
    }

    private async Task RevealRule(Color color)
    {
        if (Show.HasActiveGame)
        {
            if (Show.DrawRule(color))
            {
                message = null;
                noteModalOpen = color != Color.White;
            }
            else message = $"Acabaram as regras {color.Label()} deste jogo.";
            return;
        }

        var items = await Catalog.GetRulesAsync(color, includeInactive: false);
        var pick = Show.PickRandom($"rule-{color}", items, r => r.Id);
        if (pick is null)
        {
            message = $"Nenhuma regra ativa na cor {color.Label()}. Cadastre em Regras.";
            return;
        }
        message = null;
        if (color == Color.White)
        {
            Show.ArmAudienceRule(pick);
            noteModalOpen = false;
        }
        else
        {
            Show.ShowRule(pick);
            noteModalOpen = true;
        }
    }

    private void ConfirmAudienceReveal()
    {
        Show.RevealAudienceRule();
        noteModalOpen = true;
    }

    private void CancelAudienceReveal()
    {
        Show.CancelAudiencePending();
        noteModalOpen = false;
    }

    private void MostrarRegra(RuleDefinition r)
    {
        Show.ShowRule(r);
        noteModalOpen = true;
    }

    private void InverterRegra(RuleDefinition r)
    {
        Show.ToggleRule(r);
        noteModalOpen = true;
    }

    private async Task RevealModifier()
    {
        if (!Show.HasActiveGame)
        {
            var items = await Catalog.GetModifiersAsync(includeInactive: false);
            if (items.Count == 0)
            {
                message = "Nenhum modificador ativo. Cadastre em Modificadores.";
                return;
            }
            Show.SetModifierPool(items);
        }

        message = Show.DrawModifier()
            ? null
            : (Show.HasActiveGame
                ? "Este jogo não tem modificadores."
                : "Nenhum modificador ativo. Cadastre em Modificadores.");
    }

    private async Task RevealAction()
    {
        if (Show.HasActiveGame)
        {
            message = Show.DrawAction() ? null : "Acabaram as ações deste jogo.";
            return;
        }

        var items = await Catalog.GetActionsAsync(includeInactive: false);
        var pick = Show.PickRandom("action", items, a => a.Id);
        if (pick is null)
        {
            message = "Nenhuma ação ativa. Cadastre em Ações.";
            return;
        }
        message = null;
        Show.SetReveal(new Reveal(RevealKind.Action, string.Empty, pick.Text, null));
    }

    private static string ChipLabel(Reveal c) => c switch
    {
        { Kind: RevealKind.Rule, Color: Color.White } => "Regra da Plateia",
        { Kind: RevealKind.Rule } => "Regra",
        { Kind: RevealKind.Modifier } => "Modificador",
        { Kind: RevealKind.Action } => "Ação",
        _ => string.Empty,
    };

    private static string ButtonClass(Color color) => color switch
    {
        Color.Blue => "is-blue",
        Color.Red => "is-red",
        Color.Green => "is-green",
        Color.White => "is-white",
        _ => "is-blue",
    };

    public void Dispose() => Show.Changed -= OnChanged;
}
